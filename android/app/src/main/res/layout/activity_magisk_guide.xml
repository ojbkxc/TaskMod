<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/primary">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="安装 TaskMod 模块"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tv_current_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="准备开始…"
            android:textSize="14sp"
            android:textColor="#B0B0FF"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- 进度条 -->
    <LinearLayout
        android:id="@+id/progress_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true" />
    </LinearLayout>

    <!-- 步骤容器 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:id="@+id/steps_container">

            <!-- 步骤 1: 检测 Magisk -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/step1_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A2A3C">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/step1_status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/presence_invisible" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="检测 Magisk 环境"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/step1_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="等待检测…"
                            android:textSize="13sp"
                            android:textColor="#71717A"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 步骤 2: 获取版本 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/step2_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A2A3C">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/step2_status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/presence_invisible" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="获取最新版本"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/step2_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="等待获取…"
                            android:textSize="13sp"
                            android:textColor="#71717A"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/step2_version"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="@color/primary"
                            android:layout_marginTop="4dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 步骤 3: 下载模块 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/step3_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A2A3C">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/step3_status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/presence_invisible" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="下载模块"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/step3_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="等待下载…"
                            android:textSize="13sp"
                            android:textColor="#71717A"
                            android:layout_marginTop="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_download"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="下载"
                            android:visibility="gone"
                            android:layout_marginTop="8dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="@color/primary" />

                        <ProgressBar
                            android:id="@+id/download_progress"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:visibility="gone"
                            android:layout_marginTop="8dp"
                            android:progressTint="@color/primary" />

                        <TextView
                            android:id="@+id/download_progress_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="#71717A"
                            android:visibility="gone"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 步骤 4: 刷入模块 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/step4_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A2A3C">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/step4_status"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/presence_invisible" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="刷入模块"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/step4_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="等待操作…"
                            android:textSize="13sp"
                            android:textColor="#71717A"
                            android:layout_marginTop="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_flash"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="打开 Magisk 刷入"
                            android:visibility="gone"
                            android:layout_marginTop="8dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="@color/primary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 提示信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="刷入模块后需重启设备，TaskMod 服务将自动启动。\n\n模块提供内核级保活，比 APK 内置服务更稳定。"
                android:textSize="12sp"
                android:textColor="#52525B"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="重新检测"
            android:visibility="gone"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_skip"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="跳过，使用内置服务"
            app:cornerRadius="24dp" />
    </LinearLayout>

</LinearLayout>
